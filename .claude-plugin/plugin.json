{
	"name": "frontend-setup",
	"version": "1.1.0",
	"description": "Help non-technical users set up the Buildertrend frontend on their local machine.",
	"author": {
		"name": "Buildertrend",
		"email": "michael.hanson@buildertrend.com"
	},
	"license": "MIT",
	"homepage": "https://github.com/buildertrend/frontend-setup",
